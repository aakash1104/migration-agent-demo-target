{
  "name": "migration-agent-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Cursor-based Moment.js -> date-fns migration prototype. Demonstrates @cursor/sdk + rules + subagents + hooks composing into a real enterprise-grade migration workflow.",
  "type": "module",
  "scripts": {
    "migrate": "tsx orchestrator/orchestrate.ts",
    "migrate:cloud": "tsx orchestrator/orchestrate.ts --cloud",
    "migrate:cloud:batch": "tsx orchestrator/orchestrate.ts --cloud --batch",
    "discover": "tsx orchestrator/orchestrate.ts --discover-only",
    "smoke": "tsx orchestrator/smoke.ts",
    "scoreboard": "tsx orchestrator/scoreboard.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "chalk": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
